<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Akventure – AI Business Simulation Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="bg-[#0d0d0d] text-white">

  <!-- Hero Section -->
  <section class="min-h-screen flex flex-col justify-center items-center text-center px-6">
    <h1 class="text-4xl md:text-6xl font-extrabold mb-6 bg-gradient-to-r from-blue-500 to-purple-500 text-transparent bg-clip-text">
      Build. Simulate. Scale.
    </h1>
    <p class="text-gray-400 max-w-2xl mb-8 text-lg">
      Akventure is an AI-powered business simulation platform that lets entrepreneurs
      test strategies in a virtual market before going real.
    </p>
    <div class="flex gap-4">
      <button class="bg-blue-600 hover:bg-blue-700 px-6 py-3 rounded-xl font-semibold transition">
        Start Simulation
      </button>
      <button class="border border-purple-500 text-purple-400 hover:bg-purple-600 hover:text-white px-6 py-3 rounded-xl transition">
        Watch Demo
      </button>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-6 bg-[#111111]">
    <h2 class="text-3xl font-bold text-center mb-12">Core Features</h2>
    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      
      <div class="bg-[#1a1a1a] p-8 rounded-2xl hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-4 text-blue-400">AI Market Simulation</h3>
        <p class="text-gray-400">
          Test your business ideas in a realistic AI-powered market environment.
        </p>
      </div>

      <div class="bg-[#1a1a1a] p-8 rounded-2xl hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-4 text-purple-400">Risk-Free Strategy Testing</h3>
        <p class="text-gray-400">
          Experiment with pricing, marketing, and scaling without real-world losses.
        </p>
      </div>

      <div class="bg-[#1a1a1a] p-8 rounded-2xl hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-4 text-blue-400">Real-Time Insights</h3>
        <p class="text-gray-400">
          Get AI-driven analytics to optimize your business decisions instantly.
        </p>
      </div>

    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 px-6">
    <h2 class="text-3xl font-bold text-center mb-12">How It Works</h2>
    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto text-center">
      
      <div>
        <div class="text-4xl font-bold text-blue-500 mb-4">01</div>
        <h3 class="font-semibold mb-2">Create Business Model</h3>
        <p class="text-gray-400">Define your product, pricing, and target market.</p>
      </div>

      <div>
        <div class="text-4xl font-bold text-purple-500 mb-4">02</div>
        <h3 class="font-semibold mb-2">Simulate Market</h3>
        <p class="text-gray-400">Run your business inside our AI-powered simulation engine.</p>
      </div>

      <div>
        <div class="text-4xl font-bold text-blue-500 mb-4">03</div>
        <h3 class="font-semibold mb-2">Analyze & Optimize</h3>
        <p class="text-gray-400">Improve strategy using real-time AI insights.</p>
      </div>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-6 bg-gradient-to-r from-blue-600 to-purple-600 text-center">
    <h2 class="text-3xl font-bold mb-6">Ready to Train Like a CEO?</h2>
    <button class="bg-black text-white px-8 py-4 rounded-xl font-semibold hover:opacity-80 transition">
      Join Beta Now
    </button>
  </section>

  <!-- Footer -->
  <footer class="bg-black py-10 text-center text-gray-500">
    <p>© 2026 Akventure. All rights reserved.</p>
  </footer>

</body>
</html>
